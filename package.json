{
  "name": "africoin-backend",
  "version": "1.0.0",
  "description": "AfriCoin Express API backend with PostgreSQL, Stripe, PayFast, and Solana integration",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "migrate": "ts-node src/database/migrations.ts",
    "seed": "ts-node src/database/seed.ts",
    "test": "vitest"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "jsonwebtoken": "^9.1.2",
    "bcryptjs": "^2.4.3",
    "stripe": "^14.16.0",
    "axios": "^1.6.5",
    "@solana/web3.js": "^1.87.6",
    "@solana/spl-token": "^0.3.10",
    "joi": "^17.11.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "express-rate-limit": "^7.1.5",
    "uuid": "^9.0.1",
    "nodemailer": "^6.9.7",
    "sequelize": "^6.35.2",
    "sequelize-cli": "^6.6.0",
    "winston": "^3.11.0",
    "redis": "^4.6.12",
    "ioredis": "^5.3.2",
    "joi-password-complexity": "^5.1.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "speakeasy": "^2.0.0",
    "qrcode": "^1.5.3",
    "twilio": "^4.0.2",
    "crypto": "^1.0.1",
    "prom-client": "^15.0.0",
    "node-schedule": "^2.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/uuid": "^9.0.7",
    "@types/nodemailer": "^6.4.14",
    "@types/speakeasy": "^2.0.10",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "prettier": "^3.1.1",
    "vitest": "^1.1.0",
    "@vitest/ui": "^1.1.0",
    "supertest": "^6.3.3",
    "@types/supertest": "^2.0.12"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
