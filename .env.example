# Server Configuration
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# Database
# For SQLite (development): file:./dev.db
# For PostgreSQL: postgresql://user:password@localhost:5432/africoin_db
DATABASE_URL=file:./dev.db

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Stripe Payment Gateway
STRIPE_PUBLIC_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret

# PayFast Payment Gateway (South Africa)
PAYFAST_MERCHANT_ID=your_merchant_id
PAYFAST_MERCHANT_KEY=your_merchant_key
PAYFAST_PASSPHRASE=your_passphrase
PAYFAST_API_URL=https://api.payfast.co.za

# Solana Blockchain Integration
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_NETWORK=mainnet-beta
SOLANA_PROGRAM_ID=AfriCoinProgramIdHere

# KYC/Identity Verification
STRIPE_IDENTITY_API_KEY=sk_test_your_key

# Email Service (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Logging
LOG_LEVEL=debug
